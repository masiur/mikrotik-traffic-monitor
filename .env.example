# MikroTik Router Configuration
# Add multiple IPs comma-separated — app will try each until one connects
MIKROTIK_HOSTS=192.168.88.1,10.0.0.1

# RouterOS API credentials
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_password_here

# RouterOS API port (default 8728, SSL: 8729)
MIKROTIK_PORT=8728

# Interfaces to monitor (comma-separated)
# Run /interface/print on your router to see available names
MIKROTIK_INTERFACES=ether1,ether2,ether3

# Polling interval in seconds
POLL_INTERVAL=1

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=3000
